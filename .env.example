# Copy to .env and fill in. Everything is optional — unset values fall back to offline defaults.

# --- persistence ---
# LAVARD_DATABASE_URL=postgresql+psycopg://lavard:lavard@localhost:5432/lavard
# LAVARD_REDIS_URL=redis://localhost:6379/0

# --- model backend (OpenAI-compatible; provider-agnostic, spec §0.5) ---
# If unset, LAVARD uses the deterministic heuristic planner (runs fully offline).
# LAVARD_MODEL_ENDPOINT=https://your-openai-compatible-host/v1
# LAVARD_MODEL_API_KEY=sk-...
# LAVARD_MODEL_TRIVIAL=...
# LAVARD_MODEL_ROUTINE=...
# LAVARD_MODEL_COMPLEX=...
# LAVARD_MODEL_CRITICAL=...

# --- governance defaults (QUESTIONS.md Q-BUDGET-1) ---
# LAVARD_JOB_BUDGET_USD=25
# LAVARD_ROOM_TURN_LIMIT=40
# LAVARD_AGENT_TURN_LIMIT=8

# --- OKX onchain reads (Phase 2+; adapters are mock-backed until these are set) ---
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=
